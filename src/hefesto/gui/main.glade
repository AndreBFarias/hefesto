                      </object>
                    </child>
                    <child>
                      <object class="GtkButton" id="rumble_stop">
                        <property name="label">Parar</property>
                        <signal name="clicked" handler="on_rumble_stop"/>
                      </object>
                    </child>
                  </object>
                  <packing><property name="expand">False</property></packing>
                </child>

                <child>
                  <object class="GtkLabel" id="rumble_info">
                    <property name="label">&lt;i&gt;Os motores do DualSense têm janela mínima de 20 ms entre comandos (throttle do daemon). Pressione &quot;Testar por 500 ms&quot; para sentir um pulso curto.&lt;/i&gt;</property>
                    <property name="use-markup">True</property>
                    <property name="xalign">0</property>
                    <property name="wrap">True</property>
                  </object>
                  <packing><property name="expand">False</property></packing>
                </child>
              </object>
            </child>
            <child type="tab">
              <object class="GtkLabel"><property name="label">Rumble</property></object>
            </child>


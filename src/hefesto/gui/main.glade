                </child>
              </object>
            </child>
            <child type="tab">
              <object class="GtkLabel"><property name="label">Emulação</property></object>
            </child>

            <!-- Aba Mouse -->
            <child>
              <object class="GtkBox" id="tab_mouse">
                <property name="orientation">vertical</property>
                <property name="margin">12</property>
                <property name="spacing">10</property>

                <child>
                  <object class="GtkBox">
                    <property name="orientation">horizontal</property>
                    <property name="spacing">10</property>
                    <child>
                      <object class="GtkLabel">
                        <property name="label">&lt;b&gt;Emular mouse+teclado&lt;/b&gt;</property>
                        <property name="use-markup">True</property>
                        <property name="xalign">0</property>
                      </object>
                      <packing><property name="expand">True</property></packing>
                    </child>
                    <child>
                      <object class="GtkSwitch" id="mouse_emulation_toggle">
                        <property name="active">False</property>
                        <signal name="state-set" handler="on_mouse_toggle_set"/>
                      </object>
                      <packing><property name="expand">False</property></packing>
                    </child>
                  </object>
                  <packing><property name="expand">False</property></packing>
                </child>

                <child>
                  <object class="GtkLabel" id="mouse_uinput_status_label">
                    <property name="label">—</property>
                    <property name="use-markup">True</property>
                    <property name="xalign">0</property>
                  </object>
                  <packing><property name="expand">False</property></packing>
                </child>

                <child>
                  <object class="GtkSeparator"><property name="orientation">horizontal</property></object>
                  <packing><property name="expand">False</property></packing>
                </child>

                <child>
                  <object class="GtkGrid" id="mouse_speed_grid">
                    <property name="row-spacing">8</property>
                    <property name="column-spacing">10</property>
                    <style><class name="hefesto-card"/></style>
                    <child>
                      <object class="GtkLabel">
                        <property name="label">Velocidade do cursor:</property>
                        <property name="xalign">1</property>
                      </object>
                      <packing><property name="left-attach">0</property><property name="top-attach">0</property></packing>
                    </child>
                    <child>
                      <object class="GtkScale" id="mouse_speed_scale">
                        <property name="adjustment">mouse_speed_adj</property>
                        <property name="digits">0</property>
                        <property name="draw-value">True</property>
                        <property name="value-pos">right</property>
                        <property name="hexpand">True</property>
                        <signal name="value-changed" handler="on_mouse_speed_changed"/>
                      </object>
                      <packing><property name="left-attach">1</property><property name="top-attach">0</property></packing>
                    </child>
                    <child>
                      <object class="GtkLabel">
                        <property name="label">Velocidade da rolagem:</property>
                        <property name="xalign">1</property>
                      </object>
                      <packing><property name="left-attach">0</property><property name="top-attach">1</property></packing>
                    </child>
                    <child>
                      <object class="GtkScale" id="mouse_scroll_speed_scale">
                        <property name="adjustment">mouse_scroll_speed_adj</property>
                        <property name="digits">0</property>
                        <property name="draw-value">True</property>
                        <property name="value-pos">right</property>
                        <property name="hexpand">True</property>
                        <signal name="value-changed" handler="on_mouse_scroll_speed_changed"/>
                      </object>
                      <packing><property name="left-attach">1</property><property name="top-attach">1</property></packing>
                    </child>
                  </object>
                  <packing><property name="expand">False</property></packing>
                </child>

                <child>
                  <object class="GtkSeparator"><property name="orientation">horizontal</property></object>
                  <packing><property name="expand">False</property></packing>
                </child>

                <child>
                  <object class="GtkFrame" id="mouse_mapping_frame">
                    <style><class name="hefesto-card"/></style>
                    <child>
                      <object class="GtkBox">
                        <property name="orientation">vertical</property>
                        <property name="spacing">6</property>
                        <property name="margin">10</property>
                        <child>
                          <object class="GtkLabel">
                            <property name="label">&lt;b&gt;Mapeamento&lt;/b&gt;</property>
                            <property name="use-markup">True</property>
                            <property name="xalign">0</property>
                          </object>
                          <packing><property name="expand">False</property></packing>
                        </child>
                        <child>
                          <object class="GtkGrid" id="mouse_mapping_grid">
                            <property name="row-spacing">4</property>
                            <property name="column-spacing">8</property>
                            <child>
                              <object class="GtkLabel"><property name="label">Cruz (X) ou L2</property><property name="xalign">0</property></object>
                              <packing><property name="left-attach">0</property><property name="top-attach">0</property></packing>
                            </child>
                            <child>
                              <object class="GtkLabel"><property name="label">→</property><property name="xalign">0.5</property></object>
                              <packing><property name="left-attach">1</property><property name="top-attach">0</property></packing>
                            </child>
                            <child>
                              <object class="GtkLabel"><property name="label">Botão esquerdo</property><property name="xalign">0</property></object>
                              <packing><property name="left-attach">2</property><property name="top-attach">0</property></packing>
                            </child>
                            <child>
                              <object class="GtkLabel"><property name="label">Triângulo (△) ou R2</property><property name="xalign">0</property></object>
                              <packing><property name="left-attach">0</property><property name="top-attach">1</property></packing>
                            </child>
                            <child>
                              <object class="GtkLabel"><property name="label">→</property><property name="xalign">0.5</property></object>
                              <packing><property name="left-attach">1</property><property name="top-attach">1</property></packing>
                            </child>
                            <child>
                              <object class="GtkLabel"><property name="label">Botão direito</property><property name="xalign">0</property></object>
                              <packing><property name="left-attach">2</property><property name="top-attach">1</property></packing>
                            </child>
                            <child>
                              <object class="GtkLabel"><property name="label">R3 (clique no analógico direito)</property><property name="xalign">0</property></object>
                              <packing><property name="left-attach">0</property><property name="top-attach">2</property></packing>
                            </child>
                            <child>
                              <object class="GtkLabel"><property name="label">→</property><property name="xalign">0.5</property></object>
                              <packing><property name="left-attach">1</property><property name="top-attach">2</property></packing>
                            </child>
                            <child>
                              <object class="GtkLabel"><property name="label">Botão do meio</property><property name="xalign">0</property></object>
                              <packing><property name="left-attach">2</property><property name="top-attach">2</property></packing>
                            </child>
                            <child>
                              <object class="GtkLabel"><property name="label">Círculo (○)</property><property name="xalign">0</property></object>
                              <packing><property name="left-attach">0</property><property name="top-attach">3</property></packing>
                            </child>
                            <child>
                              <object class="GtkLabel"><property name="label">→</property><property name="xalign">0.5</property></object>
                              <packing><property name="left-attach">1</property><property name="top-attach">3</property></packing>
                            </child>
                            <child>
                              <object class="GtkLabel"><property name="label">Enter</property><property name="xalign">0</property></object>
                              <packing><property name="left-attach">2</property><property name="top-attach">3</property></packing>
                            </child>
                            <child>
                              <object class="GtkLabel"><property name="label">Quadrado (□)</property><property name="xalign">0</property></object>
                              <packing><property name="left-attach">0</property><property name="top-attach">4</property></packing>
                            </child>
                            <child>
                              <object class="GtkLabel"><property name="label">→</property><property name="xalign">0.5</property></object>
                              <packing><property name="left-attach">1</property><property name="top-attach">4</property></packing>
                            </child>
                            <child>
                              <object class="GtkLabel"><property name="label">Esc</property><property name="xalign">0</property></object>
                              <packing><property name="left-attach">2</property><property name="top-attach">4</property></packing>
                            </child>
                            <child>
                              <object class="GtkLabel"><property name="label">D-pad (↑↓←→)</property><property name="xalign">0</property></object>
                              <packing><property name="left-attach">0</property><property name="top-attach">5</property></packing>
                            </child>
                            <child>
                              <object class="GtkLabel"><property name="label">→</property><property name="xalign">0.5</property></object>
                              <packing><property name="left-attach">1</property><property name="top-attach">5</property></packing>
                            </child>
                            <child>
                              <object class="GtkLabel"><property name="label">Setas do teclado</property><property name="xalign">0</property></object>
                              <packing><property name="left-attach">2</property><property name="top-attach">5</property></packing>
                            </child>
                            <child>
                              <object class="GtkLabel"><property name="label">Analógico esquerdo</property><property name="xalign">0</property></object>
                              <packing><property name="left-attach">0</property><property name="top-attach">6</property></packing>
                            </child>
                            <child>
                              <object class="GtkLabel"><property name="label">→</property><property name="xalign">0.5</property></object>
                              <packing><property name="left-attach">1</property><property name="top-attach">6</property></packing>
                            </child>
                            <child>
                              <object class="GtkLabel"><property name="label">Movimento do cursor</property><property name="xalign">0</property></object>
                              <packing><property name="left-attach">2</property><property name="top-attach">6</property></packing>
                            </child>
                            <child>
                              <object class="GtkLabel"><property name="label">Analógico direito</property><property name="xalign">0</property></object>
                              <packing><property name="left-attach">0</property><property name="top-attach">7</property></packing>
                            </child>
                            <child>
                              <object class="GtkLabel"><property name="label">→</property><property name="xalign">0.5</property></object>
                              <packing><property name="left-attach">1</property><property name="top-attach">7</property></packing>
                            </child>
                            <child>
                              <object class="GtkLabel"><property name="label">Rolagem vertical e horizontal</property><property name="xalign">0</property></object>
                              <packing><property name="left-attach">2</property><property name="top-attach">7</property></packing>
                            </child>
                          </object>
                          <packing><property name="expand">False</property></packing>
                        </child>
                      </object>
                    </child>
                  </object>
                  <packing><property name="expand">False</property></packing>
                </child>

                <child>
                  <object class="GtkLabel">
                    <property name="label">&lt;i&gt;Útil para navegar o desktop, apresentações e jogos que só aceitam mouse/teclado. Requer módulo uinput carregado e regra udev (ver aba Emulação).&lt;/i&gt;</property>
                    <property name="use-markup">True</property>
                    <property name="xalign">0</property>
                    <property name="wrap">True</property>
                  </object>
                  <packing><property name="expand">False</property></packing>
                </child>

                <!-- FEAT-KEYBOARD-UI-01: seção de Teclado (bindings por perfil) -->
                <child>
                  <object class="GtkSeparator">
                    <property name="orientation">horizontal</property>
                  </object>
                  <packing><property name="expand">False</property></packing>
                </child>
                <child>
                  <object class="GtkLabel">
                    <property name="label">&lt;b&gt;Teclado (bindings do perfil ativo)&lt;/b&gt;</property>
                    <property name="use-markup">True</property>
                    <property name="xalign">0</property>
                  </object>
                  <packing><property name="expand">False</property></packing>
                </child>
                <child>
                  <object class="GtkLabel" id="key_bindings_legend">
                    <property name="label">Formato: KEY_* (ex: KEY_C, KEY_ENTER) ou __OPEN_OSK__/__CLOSE_OSK__. Combos com '+' (ex: KEY_LEFTALT+KEY_TAB).</property>
                    <property name="use-markup">True</property>
                    <property name="xalign">0</property>
                    <property name="wrap">True</property>
                  </object>
                  <packing><property name="expand">False</property></packing>
                </child>
                <child>
                  <object class="GtkScrolledWindow">
                    <property name="visible">True</property>
                    <property name="can-focus">True</property>
                    <property name="shadow-type">in</property>
                    <property name="min-content-height">200</property>
                    <child>
                      <object class="GtkTreeView" id="key_bindings_treeview">
                        <property name="visible">True</property>
                        <property name="can-focus">True</property>
                        <property name="headers-visible">True</property>
                        <property name="rules-hint">True</property>
                      </object>
                    </child>
                  </object>
                  <packing><property name="expand">True</property><property name="fill">True</property></packing>
                </child>
                <child>
                  <object class="GtkBox" id="key_bindings_button_row">
                    <property name="orientation">horizontal</property>
                    <property name="spacing">6</property>
                    <property name="homogeneous">False</property>
                    <child>
                      <object class="GtkButton" id="key_binding_add_btn">
                        <property name="label">Adicionar</property>
                        <signal name="clicked" handler="on_key_binding_add"/>
                      </object>
                      <packing><property name="expand">False</property></packing>
                    </child>
                    <child>
                      <object class="GtkButton" id="key_binding_remove_btn">
                        <property name="label">Remover</property>
                        <signal name="clicked" handler="on_key_binding_remove"/>
                      </object>
                      <packing><property name="expand">False</property></packing>
                    </child>
                    <child>
                      <object class="GtkButton" id="key_binding_restore_btn">
                        <property name="label">Restaurar defaults</property>
                        <signal name="clicked" handler="on_key_binding_restore_defaults"/>
                      </object>
                      <packing><property name="expand">False</property></packing>
                    </child>
                  </object>
                  <packing><property name="expand">False</property></packing>
                </child>
              </object>
            </child>
            <child type="tab">
              <object class="GtkLabel"><property name="label">Mouse e Teclado</property></object>
            </child>

            <!-- Aba Firmware -->
            <child>
              <object class="GtkBox">
                <property name="orientation">vertical</property>
                <property name="spacing">12</property>
                <property name="margin-start">12</property>
                <property name="margin-end">12</property>
                <property name="margin-top">12</property>
                <property name="margin-bottom">12</property>

                <!-- Banner de risco -->
                <child>
                  <object class="GtkLabel" id="firmware_risk_banner_label">
                    <property name="label">RISCO DE BRICK. USE APENAS BLOBS OFICIAIS SONY (fwupdater.dl.playstation.net). NÃO DESCONECTE DURANTE O UPDATE.</property>
                    <property name="wrap">True</property>
                    <property name="xalign">0</property>
                    <attributes>
                      <attribute name="weight" value="bold"/>
                      <attribute name="foreground" value="#d33"/>
                    </attributes>
                  </object>
                  <packing><property name="expand">False</property></packing>
                </child>

                <!-- Frame: versão atual do controle -->
                <child>
                  <object class="GtkFrame">
                    <property name="label">Versão atual do controle</property>
                    <child>
                      <object class="GtkGrid">
                        <property name="margin-start">12</property>
                        <property name="margin-end">12</property>
                        <property name="margin-top">8</property>
                        <property name="margin-bottom">8</property>
                        <property name="row-spacing">6</property>
                        <property name="column-spacing">12</property>

                        <child>
                          <object class="GtkLabel">
                            <property name="label">Update version:</property>
                            <property name="halign">end</property>
                          </object>
                          <packing><property name="left-attach">0</property><property name="top-attach">0</property></packing>
                        </child>
                        <child>
                          <object class="GtkLabel" id="firmware_current_version_label">
                            <property name="label">—</property>
                            <property name="halign">start</property>
                            <property name="selectable">True</property>
                          </object>
                          <packing><property name="left-attach">1</property><property name="top-attach">0</property></packing>
                        </child>

                        <child>
                          <object class="GtkLabel">
                            <property name="label">Hardware:</property>
                            <property name="halign">end</property>
                          </object>
                          <packing><property name="left-attach">0</property><property name="top-attach">1</property></packing>
                        </child>
                        <child>
                          <object class="GtkLabel" id="firmware_hardware_label">
                            <property name="label">—</property>
                            <property name="halign">start</property>
                            <property name="selectable">True</property>
                          </object>
                          <packing><property name="left-attach">1</property><property name="top-attach">1</property></packing>
                        </child>

                        <child>
                          <object class="GtkLabel">
                            <property name="label">Build date:</property>
                            <property name="halign">end</property>
                          </object>
                          <packing><property name="left-attach">0</property><property name="top-attach">2</property></packing>
                        </child>
                        <child>
                          <object class="GtkLabel" id="firmware_build_date_label">
                            <property name="label">—</property>
                            <property name="halign">start</property>
                            <property name="selectable">True</property>
                          </object>
                          <packing><property name="left-attach">1</property><property name="top-attach">2</property></packing>
                        </child>

                        <child>
                          <object class="GtkButton" id="firmware_check_btn">
                            <property name="label">Verificar versão</property>
                            <property name="tooltip-text">Consulta o controle via dualsensectl info</property>
                            <signal name="clicked" handler="on_firmware_check"/>
                            <property name="halign">start</property>
                          </object>
                          <packing><property name="left-attach">0</property><property name="top-attach">3</property><property name="width">2</property></packing>
                        </child>
                      </object>
                    </child>
                  </object>
                  <packing><property name="expand">False</property></packing>
                </child>

                <!-- Frame: aplicar firmware -->
                <child>
                  <object class="GtkFrame">
                    <property name="label">Aplicar firmware (.bin)</property>
                    <child>
                      <object class="GtkBox">
                        <property name="orientation">vertical</property>
                        <property name="spacing">8</property>
                        <property name="margin-start">12</property>
                        <property name="margin-end">12</property>
                        <property name="margin-top">8</property>
                        <property name="margin-bottom">8</property>

                        <!-- Seletor de arquivo -->
                        <child>
                          <object class="GtkBox">
                            <property name="orientation">horizontal</property>
                            <property name="spacing">6</property>

                            <child>
                              <object class="GtkEntry" id="firmware_file_entry">
                                <property name="editable">False</property>
                                <property name="placeholder-text">Nenhum arquivo selecionado</property>
                                <property name="hexpand">True</property>
                              </object>
                              <packing><property name="expand">True</property><property name="fill">True</property></packing>
                            </child>

                            <child>
                              <object class="GtkButton" id="firmware_browse_btn">
                                <property name="label">Selecionar .bin…</property>
                                <property name="tooltip-text">Escolher blob de firmware local (950272 bytes)</property>
                                <signal name="clicked" handler="on_firmware_browse"/>
                              </object>
                              <packing><property name="expand">False</property></packing>
                            </child>
                          </object>
                          <packing><property name="expand">False</property></packing>
                        </child>

                        <!-- Botão aplicar -->
                        <child>
                          <object class="GtkButton" id="firmware_apply_btn">
                            <property name="label">Aplicar firmware</property>
                            <property name="tooltip-text">Envia o blob ao controle. Exige confirmação.</property>
                            <property name="sensitive">False</property>
                            <property name="halign">start</property>
                            <signal name="clicked" handler="on_firmware_apply"/>
                            <style><class name="destructive-action"/></style>
                          </object>
                          <packing><property name="expand">False</property></packing>
                        </child>

                        <!-- Progresso -->
                        <child>
                          <object class="GtkProgressBar" id="firmware_progress_bar">
                            <property name="hexpand">True</property>
                            <property name="show-text">False</property>
                          </object>
                          <packing><property name="expand">False</property></packing>
                        </child>
                      </object>
                    </child>
                  </object>
                  <packing><property name="expand">False</property></packing>
                </child>

                <!-- Status -->
                <child>
                  <object class="GtkLabel" id="firmware_status_label">
                    <property name="label">Pronto.</property>
                    <property name="xalign">0</property>
                    <property name="wrap">True</property>
                  </object>
                  <packing><property name="expand">False</property></packing>
                </child>

                <!-- Dica de origem -->
                <child>
                  <object class="GtkLabel">
                    <property name="label">&lt;i&gt;Backend: dualsensectl (MIT, nowrep/dualsensectl). Blobs oficiais: fwupdater.dl.playstation.net/fwupdater/info.json&lt;/i&gt;</property>
                    <property name="use-markup">True</property>
                    <property name="xalign">0</property>
                    <property name="wrap">True</property>
                  </object>
                  <packing><property name="expand">False</property></packing>
                </child>

              </object>
            </child>
            <child type="tab">
              <object class="GtkLabel"><property name="label">Firmware</property></object>
            </child>

          </object>
          <packing>
            <property name="expand">True</property>
            <property name="fill">True</property>
          </packing>
        </child>

        <!-- Rodape: statusbar + botoes de acao global -->
        <child>
          <object class="GtkBox" id="footer_box">
            <property name="orientation">horizontal</property>
            <property name="spacing">6</property>
            <property name="margin-start">4</property>
            <property name="margin-end">6</property>
            <property name="margin-top">2</property>
            <property name="margin-bottom">2</property>

            <!-- Statusbar ocupa espaco flexivel a esquerda -->
            <child>
              <object class="GtkStatusbar" id="status_bar">
                <property name="hexpand">True</property>
              </object>
              <packing>
                <property name="expand">True</property>
                <property name="fill">True</property>
              </packing>
            </child>

            <!-- Caixa de botoes alinhada a direita -->
            <child>
              <object class="GtkBox" id="footer_buttons_box">
                <property name="orientation">horizontal</property>
                <property name="spacing">6</property>
                <property name="valign">center</property>

                <child>
                  <object class="GtkButton" id="btn_footer_apply">
                    <property name="label">Aplicar</property>
                    <property name="tooltip-text">Envia toda a configuração (gatilhos, LEDs, rumble, mouse) ao controle</property>
                    <signal name="clicked" handler="on_apply_draft"/>
                    <style><class name="btn-apply"/></style>
                  </object>
                  <packing><property name="expand">False</property></packing>
                </child>

                <child>
                  <object class="GtkButton" id="btn_footer_save_profile">
                    <property name="label">Salvar Perfil</property>
                    <property name="tooltip-text">Salva o estado atual como um perfil nomeado</property>
                    <signal name="clicked" handler="on_save_profile"/>
                    <style><class name="btn-save"/></style>
                  </object>
                  <packing><property name="expand">False</property></packing>
                </child>

                <child>
                  <object class="GtkButton" id="btn_footer_import">
                    <property name="label">Importar</property>
                    <property name="tooltip-text">Carrega um perfil de arquivo .json</property>
                    <signal name="clicked" handler="on_import_profile"/>
                    <style><class name="btn-import"/></style>
                  </object>
                  <packing><property name="expand">False</property></packing>
                </child>

                <child>
                  <object class="GtkButton" id="btn_footer_restore_default">
                    <property name="label">Restaurar Default</property>
                    <property name="tooltip-text">Restaura o perfil 'Meu Perfil' ao estado original</property>
                    <signal name="clicked" handler="on_restore_default"/>
                    <style><class name="btn-restore"/></style>
                  </object>
                  <packing><property name="expand">False</property></packing>
                </child>

              </object>
              <packing><property name="expand">False</property></packing>
            </child>

          </object>
          <packing><property name="expand">False</property></packing>
        </child>

      </object>
    </child>
  </object>
</interface>
